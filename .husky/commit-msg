set -e

echo "Hmph. Checking your commit message, I guess..."
npx commitlint --edit "$1" || {
  echo "❌ W-what? That's not even a proper commit message! Don't make me say it twice!"
  echo "It's not like I want to help you, but... use this format:"
  echo "  feat: add new feature"
  echo "  fix: resolve bug"
  echo "  docs: update documentation"
  echo "  etc."
  exit 1
}

echo "✅ Tch. Fine, it's valid. Don't let it go to your head."
